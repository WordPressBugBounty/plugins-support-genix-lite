{
	"name": "support-genix/third-party",
	"description": "Third-party dependencies with namespace prefixing for Support Genix",
	"prefer-stable": true,
	"minimum-stability": "dev",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"coenjacobs/mozart": "^0.7",
		"league/html-to-markdown": "5.1.1",
		"pelago/emogrifier": "7.3.0",
		"sabberworm/php-css-parser": "^8.5",
		"symfony/css-selector": "^5.4 || ^6.0 || ^7.0",
		"symfony/polyfill-php80": "^1.29"
	},
	"config": {
		"platform": {
			"php": "7.4"
		}
	},
	"scripts": {
		"prefix": [
			"\"vendor/bin/mozart\" compose"
		]
	},
	"extra": {
		"mozart": {
			"dep_namespace": "ApbdWps\\Vendor\\",
			"dep_directory": "/packages/",
			"packages": [
				"league/html-to-markdown",
				"pelago/emogrifier"
			],
			"excluded_packages": [],
			"override_autoload": {},
			"classmap_directory": "/classes/",
			"classmap_prefix": "ApbdWps_Vendor_",
			"delete_vendor_directories": false
		}
	}
}
